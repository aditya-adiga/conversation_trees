{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "dotenv -e .env -- concurrently \"next dev\" \"ngrok http 3000 --url $NGROK_DOMAIN\"",
    "build": "next build",
    "start": "dotenv -e .env -- concurrently \"next start\" \"ngrok http 3000 --url $NGROK_DOMAIN\"",
    "lint": "eslint",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "validate": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
